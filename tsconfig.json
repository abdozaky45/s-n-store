/*TS Config */
{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2020",
    "module": "NodeNext",  
    "allowJs": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "checkJs": false,
  "moduleResolution": "NodeNext"
},
  "include": ["src/**/*"],
  "exclude": ["node_modules", "./dist", "./src/TDD", "jest.config.js"]
}
